{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.joecardoso13/slack",
  "title": "Slack",
  "description": "MCP server for the Slack API",
  "version": "0.1.0",
  "websiteUrl": "https://github.com/JoeCardoso13",
  "repository": {
    "url": "https://github.com/JoeCardoso13/mcp-slack",
    "source": "github"
  },
  "packages": [
    {
      "registryType": [
        "mcpb",
        "pypi"
      ],
      "registryBaseUrl": "https://pypi.org",
      "identifier": "mcp-slack",
      "version": "0.1.0",
      "transport": { "type": "stdio" },
      "environmentVariables": [
        {
          "name": "SLACK_API_KEY",
          "description": "Slack Bot Token (xoxb-...) from https://api.slack.com/apps",
          "isRequired": true,
          "isSecret": true
        }
      ]
    }
  ],
  "_meta": {
    "io.modelcontextprotocol.registry/publisher-provided": {
      "tool": "mcpb",
      "version": "0.4"
    },
    "org.mpaktrust": {
      "mtf_version": "0.1",
      "permissions": {
        "network": ["slack.com"],
        "filesystem": "none",
        "subprocess": "none"
      }
    }
  }
}
